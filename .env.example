# GMGN Twitter Intel

# Public WebSocket API authentication token.
WS_TOKEN=change-me-to-a-strong-token
API_HOST=0.0.0.0
API_PORT=8765
WS_HEARTBEAT_INTERVAL=30

# User-facing subscription: pass only a comma-separated Twitter handle list.
MONITOR_HANDLES=toly,traderpow,theunipcs,dotyyds1234,brc20niubi,jessepollak,cz_binance,heyibinance,elonmusk,cookerflips,himgajria,cryptodevinl,spidercrypto0x

# Replay and LanceDB runtime.
REPLAY_LIMIT=100
GMGN_TWITTER_HOME=
LANCEDB_PATH=
EMBEDDING_DIM=1024
SENTIMENT_BACKEND=none
LLM_MODEL=

# Internal GMGN collector strategy. These are not part of the public API.
UPSTREAM_CHAINS=sol,eth,base,bsc
UPSTREAM_CHANNELS=twitter_monitor_basic,twitter_monitor_token
GMGN_WS_APP_VERSION=20260429-12894-ccec416
GMGN_WS_PROXY=
UPSTREAM_RECONNECT_DELAY=3
UPSTREAM_HEARTBEAT_INTERVAL=25
